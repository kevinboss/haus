{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": ["build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "command": "dotnet",
      "type": "process",
      "args": ["test"],
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "haus",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "src/Haus",
        "--",
        "${input:hausArgs}"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "hausArgs",
      "description": "Arguments to pass to haus (e.g. 'state list --json')",
      "type": "promptString",
      "default": ""
    }
  ]
}
